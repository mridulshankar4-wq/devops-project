pipeline {
    agent any

    environment {
        APP_NAME = 'alertpulse'
        BACKEND_IMAGE = "alertpulse-backend:${BUILD_NUMBER}"
        FRONTEND_IMAGE = "alertpulse-frontend:${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Checking out source code...'
                checkout scm
            }
        }

        stage('Code Quality') {
            parallel {
                stage('Python Lint') {
                    steps {
                        echo '🔍 Running Python linter...'
                        sh '''
                            pip install flake8
                            flake8 backend/app --max-line-length=120 || true
                        '''
                    }
                }
                stage('JS Lint') {
                    steps {
                        echo '🔍 Running JavaScript linter...'
                        sh '''
                            cd frontend
                            npm install
                            npx eslint src --ext .js,.jsx || true
                        '''
                    }
                }
            }
        }

        stage('Build') {
            parallel {
                stage('Build Backend') {
                    steps {
                        echo '🏗 Building backend Docker image...'
                        sh "docker build -t ${BACKEND_IMAGE} ./backend"
                    }
                }
                stage('Build Frontend') {
                    steps {
                        echo '🏗 Building frontend Docker image...'
                        sh "docker build -t ${FRONTEND_IMAGE} ./frontend"
                    }
                }
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                sh '''
                    docker compose up -d
                    sleep 15
                    cd puppeteer
                    npm install
                    npm run smoke-test
                    docker compose down
                '''
            }
        }

        stage('Security Scan') {
            steps {
                echo '🔒 Running security scan...'
                sh '''
                    trivy image --exit-code 0 --severity HIGH,CRITICAL ${BACKEND_IMAGE} || true
                '''
            }
        }

        stage('Deploy Staging') {
            when {
                branch 'develop'
            }
            steps {
                echo '🚀 Deploying to staging...'
                sh 'docker compose up -d'
            }
        }

        stage('Deploy Production') {
            when {
                branch 'main'
            }
            input {
                message 'Deploy to production?'
                ok 'Yes, deploy!'
            }
            steps {
                echo '🚀 Deploying to production...'
                sh 'docker compose up -d --build'
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed. Check logs above.'
        }
        always {
            sh 'docker compose down || true'
        }
    }
}
