{
  "id": null,
  "title": "AlertPulse — Alert Fatigue Reducer",
  "uid": "alertpulse-main",
  "tags": ["alertpulse", "monitoring"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Alerts Received",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(afr_alerts_received_total)", "legendFormat": "Total" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Active Critical Alerts",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "afr_active_alerts{severity=\"critical\"}", "legendFormat": "Critical" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3,
      "title": "Noise Reduction %",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "afr_noise_reduction_percentage", "legendFormat": "Noise %" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] } } }
    },
    {
      "id": 4,
      "title": "Alerts Per Minute",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "afr_alerts_per_minute", "legendFormat": "Rate" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }] } } }
    },
    {
      "id": 5,
      "title": "Alert Ingestion Rate by Severity",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(afr_alerts_received_total{severity=\"critical\"}[1m])", "legendFormat": "Critical" },
        { "expr": "rate(afr_alerts_received_total{severity=\"high\"}[1m])", "legendFormat": "High" },
        { "expr": "rate(afr_alerts_received_total{severity=\"medium\"}[1m])", "legendFormat": "Medium" },
        { "expr": "rate(afr_alerts_received_total{severity=\"low\"}[1m])", "legendFormat": "Low" }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ff4757", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "High" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ff6b35", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ffa502", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Low" }, "properties": [{ "id": "color", "value": { "fixedColor": "#2ed573", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 6,
      "title": "Suppressed Alerts by Reason",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(afr_alerts_suppressed_total[1m])", "legendFormat": "{{reason}}" },
        { "expr": "rate(afr_noise_reduced_total[1m])", "legendFormat": "Noise Reduced" }
      ]
    },
    {
      "id": 7,
      "title": "Alert Processing Latency (P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(afr_alert_processing_seconds_bucket[5m]))", "legendFormat": "P99" },
        { "expr": "histogram_quantile(0.95, rate(afr_alert_processing_seconds_bucket[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.50, rate(afr_alert_processing_seconds_bucket[5m]))", "legendFormat": "P50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "title": "Active Alert Groups",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [{ "expr": "afr_active_groups", "legendFormat": "Active Groups" }]
    }
  ]
}
